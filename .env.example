# ==============================================================================
# AI Video Automation - Environment Configuration Template
# Sao chép file này thành .env và điền các giá trị thực tế của bạn.
# ==============================================================================

# Server Configurations
PORT=8000
HOST=0.0.0.0
NODE_ENV=development

# AI API Keys
# Gemini API Key dùng để chạy AI Agent biên tập video
GEMINI_API_KEY=your_gemini_api_key_here
# OpenAI API Key dùng để sinh giọng đọc TTS / Phụ đề Whisper (nếu chọn)
OPENAI_API_KEY=your_openai_api_key_here
# ElevenLabs API Key dùng để sinh giọng nói lồng tiếng AI cao cấp
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Runway API Key dùng để tạo chuyển động clip từ hình ảnh tĩnh
RUNWAY_API_KEY=your_runway_api_key_here

# Supabase / S3 (Database & Media Storage)
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_BUCKET_NAME=video-assets

# White-label Branding (Cấu hình thương hiệu của khách hàng)
BRAND_NAME="AI Video Automator"
BRAND_PRIMARY_COLOR="#6366F1" # Indigo
BRAND_SECONDARY_COLOR="#EC4899" # Pink
BRAND_SUPPORT_EMAIL="support@aivideo.com"
